# Database Configuration
# Get this from Neon.tech dashboard -> Connection Details -> Connection String
DATABASE_URL="postgresql://username:password@ep-xxxxx.region.aws.neon.tech/dbname?sslmode=require"

# Gmail SMTP Configuration
# Use Gmail SMTP server for sending emails
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"

# Gmail credentials
# IMPORTANT: Use an App-Specific Password, not your regular Gmail password
# Generate one at: https://myaccount.google.com/apppasswords
# (You need 2-Step Verification enabled first)
SMTP_USER="your-email@gmail.com"
SMTP_PASS="your-app-specific-password"

# Email Configuration
# Email address to receive lead notifications
SALES_EMAIL="sales@yourdomain.com"

# BCC email (optional - receives blind copy of all lead emails)
BCC_EMAIL="admin@yourdomain.com"

# From email (should match SMTP_USER)
FROM_EMAIL="your-email@gmail.com"

# Application Name (used in emails)
APP_NAME="Dr. Nitin Sunku - Orthopedic Clinic"

# ───────────────────────────────────────────────────────────────────────────────
# Analytics / Ads Tracking
# Used by the ad landing pages (e.g. /orthopedic-attibele) and the global GA tag.
# ───────────────────────────────────────────────────────────────────────────────

# Google Analytics 4 measurement ID (G-XXXXXXXXXX) or GTM container (GTM-XXXX)
# Loaded globally in app/layout.tsx.
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXXXX"

# Google Ads container (AW-XXXXXXXXX). Loaded on ad landing pages so Google Ads
# can fire conversion events. Used in app/orthopedic-attibele/layout.tsx.
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION_ID="AW-XXXXXXXXX"

# Google Ads "lead" conversion action — full string AW-XXXXXXXXX/LABEL.
# Used on /thank-you to fire the conversion when the form is submitted.
NEXT_PUBLIC_GOOGLE_ADS_CONVERSION="AW-XXXXXXXXX/CONVERSION_LABEL"

# Meta (Facebook / Instagram) Pixel ID — used for FB/IG ad attribution and
# retargeting audiences. Loaded on /book-appointment and /orthopedic-attibele.
NEXT_PUBLIC_META_PIXEL_ID="123456789012345"
